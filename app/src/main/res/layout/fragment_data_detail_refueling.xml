<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_medium">

        <!-- Mileage -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/edt_mileage_input_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="@dimen/input_field_max_width">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edt_mileage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/input_field_height_outlined"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:hint="@string/hint_mileage_optional"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/txt_mileage_input_warning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_small"
            android:text="@string/validate_error_mileage_out_of_range_total"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorError"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/edt_mileage_input_layout"
            app:layout_constraintWidth_max="@dimen/input_field_max_width" />

        <!-- Volume Container (Date-Time style for two elements) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/edt_volume_input_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            app:layout_constraintEnd_toStartOf="@+id/spn_fuel_type"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_mileage_input_warning"
            app:layout_constraintWidth_max="@dimen/input_field_max_width">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edt_volume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/input_field_height_outlined"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:hint="@string/hint_volume"
                android:inputType="number|numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <Spinner
            android:id="@+id/spn_fuel_type"
            android:layout_width="@dimen/input_field_width_medium"
            android:layout_height="@dimen/input_field_height"
            android:layout_marginStart="@dimen/margin_medium"
            app:layout_constraintBottom_toBottomOf="@+id/edt_volume_input_layout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/edt_volume_input_layout"
            app:layout_constraintTop_toTopOf="@+id/edt_volume_input_layout" />

        <!-- Partial & Station Row -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_refueling_mid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="edt_volume_input_layout,spn_fuel_type" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/chk_partial"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/input_field_height"
            android:layout_marginTop="@dimen/spacing_tiny"
            android:text="@string/label_partial"
            app:layout_constraintEnd_toStartOf="@+id/spn_station"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="@id/edt_volume_input_layout"
            app:layout_constraintTop_toBottomOf="@id/barrier_refueling_mid" />

        <Spinner
            android:id="@+id/spn_station"
            android:layout_width="@dimen/input_field_width_medium"
            android:layout_height="@dimen/input_field_height"
            android:layout_marginStart="@dimen/margin_medium"
            app:layout_constraintBottom_toBottomOf="@+id/chk_partial"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1"
            app:layout_constraintStart_toEndOf="@+id/chk_partial"
            app:layout_constraintTop_toTopOf="@+id/chk_partial"
            app:layout_constraintWidth_max="@dimen/input_field_width_medium" />

        <!-- Price -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/edt_price_input_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/chk_partial"
            app:layout_constraintWidth_max="@dimen/input_field_max_width">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edt_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/input_field_height_outlined"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:hint="@string/hint_price"
                android:inputType="number|numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Section: Advanced -->
        <TextView
            android:id="@+id/txt_section_advanced"
            style="@style/AppWidget.SectionHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/section_advanced"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/edt_price_input_layout"
            app:layout_constraintWidth_max="@dimen/input_field_max_width" />

        <!-- Date & Time Row -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/edt_date_input_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toStartOf="@+id/edt_time_input_layout"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_section_advanced"
            app:layout_constraintWidth_max="@dimen/input_field_max_width">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edt_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/input_field_height_outlined"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:hint="@string/hint_date" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/edt_time_input_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="@dimen/input_field_width_medium"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_medium"
            app:layout_constraintBottom_toBottomOf="@+id/edt_date_input_layout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/edt_date_input_layout"
            app:layout_constraintTop_toTopOf="@+id/edt_date_input_layout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edt_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/input_field_height_outlined"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:hint="@string/hint_time" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Note -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/edt_note_input_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/edt_date_input_layout"
            app:layout_constraintWidth_max="@dimen/input_field_max_width">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edt_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/input_field_height_outlined"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:hint="@string/hint_note_optional"
                android:inputType="text|textMultiLine" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Car Label -->
        <TextView
            android:id="@+id/txt_label_car"
            style="@style/AppWidget.FloatingSpinnerLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:text="@string/label_car"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/edt_note_input_layout"
            app:layout_constraintWidth_max="@dimen/input_field_max_width" />

        <Spinner
            android:id="@+id/spn_car"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/input_field_height"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txt_label_car"
            app:layout_constraintWidth_max="@dimen/button_max_width" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
