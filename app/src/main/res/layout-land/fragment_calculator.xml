<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            android:fitsSystemWindows="true"
            android:background="?attr/colorSurfaceContainer"
            app:titleTextColor="?attr/colorOnSurface"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:padding="@dimen/calculator_margin">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="@dimen/spacing_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/calculator_card_padding">

                    <Spinner
                        android:id="@+id/spn_options"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/calculator_input_height"
                        android:contentDescription="@string/calc_label_options"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/edt_input_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_small"
                        android:maxWidth="@dimen/input_field_max_width"
                        android:layout_gravity="center_horizontal"
                        app:suffixText="">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edt_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxWidth="@dimen/input_field_max_width"
                            android:layout_gravity="center_horizontal"
                            android:inputType="number"
                            android:hint="@string/hint_volume"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorHint="?attr/colorOnSurfaceVariant"
                            android:autofillHints="none">
                            <requestFocus/>
                        </com.google.android.material.textfield.TextInputEditText>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/txt_unit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="@dimen/spacing_tiny"
                        android:layout_marginEnd="@dimen/calculator_unit_margin_end"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/chart_holder"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/calculator_margin"
                android:layout_weight="3"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="@dimen/spacing_medium">

                <FrameLayout
                    android:id="@+id/chart_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/calculator_chart_card_padding"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
