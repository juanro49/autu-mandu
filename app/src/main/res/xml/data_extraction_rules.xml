<data-extraction-rules>
    <cloud-backup>
        <!-- Incluir todas las bases de datos (incluyendo archivos .shm y .wal de Room) -->
        <include domain="database" path="."/>
        <!-- Incluir todas las preferencias compartidas -->
        <include domain="sharedpref" path="."/>

        <!-- Excluir archivos que no deben salir del dispositivo (ej. tokens de sesión si los hubiera) -->
        <!-- <exclude domain="sharedpref" path="device_specific_prefs.xml"/> -->
    </cloud-backup>

    <device-transfer>
        <!-- Para transferencias directas entre dispositivos (ej. cable o Wi-Fi directo),
             solemos querer pasar todo lo que hay en cloud + archivos locales si los hay -->
        <include domain="database" path="."/>
        <include domain="sharedpref" path="."/>
        <include domain="file" path="."/>
    </device-transfer>
</data-extraction-rules>
